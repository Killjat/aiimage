# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# DeepSeek API Configuration
# 获取 API Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Server Configuration
# 重要：部署时必须修改为实际的服务器地址
APP_ENV=development
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_chat_system
DB_USER=root
DB_PASS=

# JWT Configuration (请修改为随机字符串)
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=86400

# CORS Configuration (多个来源用逗号分隔)
# 重要：部署时必须修改为前端的实际地址
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# 部署示例：
# 前后端在同一服务器：
#   APP_URL=http://your-server-ip:8080
#   CORS_ALLOWED_ORIGINS=http://your-server-ip:5173
#
# 前后端在不同服务器：
#   APP_URL=http://backend-server-ip:8080
#   CORS_ALLOWED_ORIGINS=http://frontend-server-ip:5173,https://your-domain.com
#
# 使用域名：
#   APP_URL=https://api.your-domain.com
#   CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# API 提供商说明：
# - OpenRouter: 支持 346+ 模型，包括 GPT、Claude、Gemini、Grok 等
# - DeepSeek: 性价比极高的中文模型，价格约为 GPT-4 的 1/100
#   - deepseek-chat: $0.14/1M tokens (输入), $0.28/1M tokens (输出)
#   - deepseek-reasoner: $0.55/1M tokens (输入), $2.19/1M tokens (输出)
