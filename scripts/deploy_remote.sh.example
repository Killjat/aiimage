#!/bin/bash

set -e

# 配置
REMOTE_HOST="your.server.ip"  # 修改为你的服务器IP
REMOTE_USER="root"
REMOTE_DIR="/var/www/aiimage"
LOCAL_DIR=$(pwd)
SSH_PASSWORD=""  # 在这里填写密码
DOMAIN=""  # 不使用域名

echo "=== 部署到远程服务器 $REMOTE_HOST ==="
echo ""

# 检查sshpass
if ! command -v sshpass &> /dev/null; then
    echo "错误: 需要安装 sshpass"
    echo "macOS: brew install hudochenkov/sshpass/sshpass"
    echo "Ubuntu/Debian: sudo apt-get install sshpass"
    exit 1
fi

# 检查密码是否已设置
if [ -z "$SSH_PASSWORD" ]; then
    echo "错误: 请在脚本中设置 SSH_PASSWORD"
    exit 1
fi

SSH_CMD="sshpass -p '$SSH_PASSWORD' ssh -o StrictHostKeyChecking=no"
SCP_CMD="sshpass -p '$SSH_PASSWORD' scp -o StrictHostKeyChecking=no"

# 1. 创建远程目录
echo "1. 创建远程目录..."
eval "$SSH_CMD $REMOTE_USER@$REMOTE_HOST 'mkdir -p $REMOTE_DIR/{backend,frontend}'"

# 2. 部署后端
echo "2. 部署后端代码..."
eval "$SCP_CMD -r backend/* $REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR/backend/"

# 3. 部署前端
echo "3. 构建并部署前端..."
cd frontend
npm run build
cd ..
eval "$SCP_CMD -r frontend/dist/* $REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR/frontend/dist/"

# 4. 安装依赖并配置服务
echo "4. 配置远程服务器..."
eval "$SSH_CMD $REMOTE_USER@$REMOTE_HOST" << 'ENDSSH'
cd /var/www/aiimage/backend

# 安装PHP依赖
composer install --no-dev --optimize-autoloader

# 配置Nginx
cat > /etc/nginx/conf.d/aiimage.conf << 'EOF'
server {
    listen 80;
    server_name _;
    
    location / {
        root /var/www/aiimage/frontend/dist;
        try_files $uri $uri/ /index.html;
    }
    
    location /api {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_connect_timeout 120s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
        
        add_header Access-Control-Allow-Origin * always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type" always;
        
        if ($request_method = OPTIONS) {
            return 204;
        }
    }
}
EOF

# 重启Nginx
nginx -t && systemctl reload nginx

# 配置后端服务
cat > /etc/systemd/system/aiimage-backend.service << 'EOF'
[Unit]
Description=AI Image Backend
After=network.target

[Service]
Type=simple
User=nginx
WorkingDirectory=/var/www/aiimage/backend
ExecStart=/usr/bin/php -S 0.0.0.0:8080 -t public
Restart=always

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable aiimage-backend.service
systemctl restart aiimage-backend.service

echo "部署完成！"
ENDSSH

echo ""
echo "=== 部署成功！==="
echo "访问: http://$REMOTE_HOST"
